{
  "name": "cortex",
  "workspaces": [
    "sdk",
    "demo-agent"
  ],
  "scripts": {
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "start": "next start",
    "anchor:build": "anchor build && ts-node --project scripts/tsconfig.json scripts/sync-idl.ts",
    "sync:idl": "ts-node --project scripts/tsconfig.json scripts/sync-idl.ts",
    "anchor:test": "anchor test --skip-local-validator",
    "anchor:test:local": "anchor test",
    "anchor:deploy:devnet": "anchor deploy --provider.cluster devnet",
    "demo:seed": "ts-node --project scripts/tsconfig.json scripts/seed-devnet.ts",
    "demo:agent": "ts-node --project scripts/tsconfig.json demo-agent/src/index.ts",
    "mcp:server": "ts-node --project scripts/tsconfig.json scripts/mcp-server.ts"
  },
  "description": "Cortex — Solana-native infrastructure for AI agents (programmable wallet + skill marketplace).",
  "keywords": [
    "solana",
    "anchor",
    "ai-agents",
    "x402",
    "stablecoins",
    "agentic-payments",
    "skill-marketplace"
  ],
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/client": "^1.2.0",
    "@solana/react-hooks": "^1.1.5",
    "@solana/spl-token": "^0.4.9",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.95.5",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.80",
    "@tailwindcss/postcss": "^4",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ai": "^4.3.19",
    "chai": "^4.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "mocha": "^10.8.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
