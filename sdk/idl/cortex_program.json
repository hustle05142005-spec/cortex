      "discriminator": [96, 109, 107, 40, 242, 120, 106, 218],
      "accounts": [
        {
          "name": "agent",
          "docs": [
            "The agent's signing key — typically held inside the agent",
            "runtime, never the human's wallet."
          ],
          "signer": true
        },
        {
          "name": "agent_wallet",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [97, 103, 101, 110, 116]
              },
              {
                "kind": "account",
                "path": "agent"
              }
            ]
