          "name": "owner",
          "docs": ["Human owner / payer."],
          "writable": true,
          "signer": true
        },
        {
          "name": "agent"
        },
        {
          "name": "mint"
        },
        {
          "name": "agent_wallet",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [97, 103, 101, 110, 116]
              },
              {
                "kind": "account",
                "path": "agent"
              }
            ]
          }
        },
        {
