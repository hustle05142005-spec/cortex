# Cortex frontend env vars.
#
# Copy to `.env.local` for local dev, or paste the same names into the
# Vercel project settings ("Environment Variables") for prod.
#
# All values default to devnet so the demo works out of the box; override
# CORTEX_RPC_URL with a Helius/Triton/QuickNode endpoint in production
# to avoid the public devnet RPC's 100 req/10s rate limit.

NEXT_PUBLIC_CORTEX_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CORTEX_CLUSTER=devnet
