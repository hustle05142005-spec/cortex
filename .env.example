# Cortex frontend env vars.
#
# Copy to `.env.local` for local dev, or paste the same names into the
# Vercel project settings ("Environment Variables") for prod.
#
# All values default to devnet so the demo works out of the box; override
# CORTEX_RPC_URL with a Helius/Triton/QuickNode endpoint in production
# to avoid the public devnet RPC's 100 req/10s rate limit.

NEXT_PUBLIC_CORTEX_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CORTEX_CLUSTER=devnet
NEXT_PUBLIC_CORTEX_PROGRAM_ID=DBUXLUHZk8UEGJgdbAAaazTuLoCKbReDF1tNPa5fMprV
NEXT_PUBLIC_CORTEX_MINT=9QtDZ1ojHg8UtUtcxjzZ2Xb24Z8vRJ3vEiVgBSAskpn5
NEXT_PUBLIC_DEMO_AGENT_PUBKEY=2deDn2z1Mi6GUWPMe3248Ak36ubGPiqSmEcY9yBTdNVB

# Server-only — the mint-authority secret for the devUSDC faucet on /agent.
# Same format as `solana-keygen` writes (a JSON array of 64 numbers). When
# unset the dashboard's "Get devUSDC" button shows a hint instead of minting.
# CORTEX_FAUCET_AUTHORITY=[1,2,3,...]

# --- Live skill: cortex-search-live (Tavily-backed) ---
# Required so /api/skills/cortex-search can verify on-chain proofs against
# the registered author key. Same as `config/demo.json` -> authors.default.
CORTEX_SEARCH_AUTHOR=9e7Gbzvb8Ctcw5vnPoh9Yfi8FFYLvEPmC3x4nu2BVoH2

# Optional — when unset the route returns a stub response (still proving
# end-to-end x402 settlement). Get a free key at https://tavily.com.
# TAVILY_API_KEY=tvly-...
